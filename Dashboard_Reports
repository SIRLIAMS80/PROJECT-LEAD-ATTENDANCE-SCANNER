function loadTrendChart() {
  const t = dashData.weeklyTrend || { days:[], present:[], absent:[], late:[] };
  if (!t.days.length) { document.getElementById("trend-chart").innerHTML = `<div class="empty">No trend data yet</div>`; return; }

  const W=680,H=170,padL=44,padB=28,padT=14,padR=14;
  const iW=W-padL-padR, iH=H-padB-padT;
  const max = Math.max(1, ...t.present, ...t.absent, ...t.late) * 1.15;
  const gp = t.days.length > 1 ? iW/(t.days.length-1) : 0;

  function poly(arr,c) {
    const p = arr.map((v,i)=>`${padL+i*gp},${padT+iH-(v/max)*iH}`);
    return `<polygon points="${p.join(" ")} ${padL+gp*(arr.length-1)},${padT+iH} ${padL},${padT+iH}" fill="${c}" opacity=".1"/>
            <polyline points="${p.join(" ")}" fill="none" stroke="${c}" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>`;
  }

  let svg = `<svg viewBox="0 0 ${W} ${H}" style="width:100%;height:170px">`;
  for(let i=0;i<=4;i++) {
    const y = padT + (iH/4)*i;
    svg += `<line x1="${padL}" y1="${y}" x2="${W-padR}" y2="${y}" stroke="rgba(255,255,255,.06)" stroke-width="1"/>`;
    svg += `<text x="${padL-6}" y="${y+4}" text-anchor="end" font-size="9" fill="#94a3b8">${Math.round(max-max/4*i)}</text>`;
  }
  svg += poly(t.present,"#10b981") + poly(t.late,"#f59e0b") + poly(t.absent,"#ef4444");
  t.days.forEach((d,i) => {
    const x=padL+i*gp, yp=padT+iH-(t.present[i]/max)*iH, ya=padT+iH-(t.absent[i]/max)*iH;
    svg += `<circle cx="${x}" cy="${yp}" r="4" fill="#10b981"/><circle cx="${x}" cy="${ya}" r="4" fill="#ef4444"/>`;
    svg += `<text x="${x}" y="${H-6}" text-anchor="middle" font-size="10" fill="#94a3b8">${d}</text>`;
  });
  svg += `</svg><div style="display:flex;gap:16px;padding:0 4px 4px;font-size:11px;font-family:var(--mono)">
    <span style="color:var(--green);display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:12px;height:2px;background:var(--green);border-radius:1px"></span>Present</span>
    <span style="color:var(--amber);display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:12px;height:2px;background:var(--amber);border-radius:1px"></span>Late</span>
    <span style="color:var(--red);display:flex;align-items:center;gap:5px"><span style="display:inline-block;width:12px;height:2px;background:var(--red);border-radius:1px"></span>Absent</span></div>`;
  document.getElementById("trend-chart").innerHTML = svg;
}

