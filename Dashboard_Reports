<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Project LEAD — Executive Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --navy:#0a0f1e; --navy2:#111827; --navy3:#1a2235; --navy4:#242f45;
  --teal:#00d4aa; --teal2:#00b894; --teal3:rgba(0,212,170,.12);
  --amber:#f59e0b; --amber2:rgba(245,158,11,.12);
  --red:#ef4444; --red2:rgba(239,68,68,.12);
  --green:#10b981; --green2:rgba(16,185,129,.12);
  --blue:#3b82f6; --blue2:rgba(59,130,246,.12);
  --purple:#8b5cf6; --purple2:rgba(139,92,246,.12);
  --text:#f1f5f9; --muted:#94a3b8; --border:rgba(255,255,255,.07);
  --card:rgba(255,255,255,.03); --radius:12px;
  --mono:'JetBrains Mono',monospace; --sans:'Inter',system-ui,sans-serif;
  --glow-teal:0 0 20px rgba(0,212,170,.25);
  --shadow:0 2px 16px rgba(0,0,0,.4);
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--sans);background:var(--navy);color:var(--text);min-height:100vh;font-size:14px;}

/* ── LOGIN SCREEN ── */
#login-screen{
  position:fixed;inset:0;background:var(--navy);z-index:1000;
  display:flex;align-items:center;justify-content:center;
}
.login-box{
  width:360px;background:var(--card);border:1px solid var(--border);
  border-radius:16px;padding:32px 28px;backdrop-filter:blur(20px);
  box-shadow:0 20px 60px rgba(0,0,0,.5);
}
.login-logo{width:54px;height:54px;border-radius:14px;background:linear-gradient(135deg,var(--teal),var(--blue));display:flex;align-items:center;justify-content:center;font-size:26px;margin:0 auto 14px;}
.login-box h2{text-align:center;font-size:18px;font-weight:800;}
.login-box p{text-align:center;font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:3px;margin-bottom:22px;}
.login-field{margin-bottom:14px;}
.login-field label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:5px;}
.login-field input{
  width:100%;padding:10px 13px;border:1.5px solid var(--border);border-radius:8px;
  background:var(--navy3);color:var(--text);font-size:13px;outline:none;font-family:var(--mono);
}
.login-field input:focus{border-color:var(--teal);}
.login-btn{
  width:100%;padding:11px;border:none;border-radius:8px;background:var(--teal);
  color:var(--navy);font-size:14px;font-weight:800;cursor:pointer;margin-top:6px;
}
.login-btn:hover{background:var(--teal2);}
.login-btn:disabled{opacity:.5;}
.login-error{
  background:var(--red2);color:var(--red);padding:8px 12px;border-radius:7px;
  font-size:12px;margin-bottom:14px;display:none;font-weight:600;
}
.login-error.show{display:block;}
.login-roles{display:flex;gap:6px;justify-content:center;margin-top:18px;}
.role-tag{font-size:9px;font-family:var(--mono);color:var(--muted);background:var(--navy3);padding:3px 8px;border-radius:6px;}

/* ── LAYOUT (unchanged from before) ── */
.shell{display:flex;min-height:100vh;}
.sidebar{width:230px;flex-shrink:0;background:var(--navy2);border-right:1px solid var(--border);position:fixed;top:0;bottom:0;left:0;z-index:100;display:flex;flex-direction:column;overflow-y:auto;}
.sb-brand{padding:20px 16px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.sb-icon{width:40px;height:40px;border-radius:10px;flex-shrink:0;background:linear-gradient(135deg,var(--teal),var(--blue));display:flex;align-items:center;justify-content:center;font-size:20px;}
.sb-name{font-size:14px;font-weight:800;color:var(--text);}
.sb-sub{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:1px;}
.sb-user{margin:12px 12px 0;padding:8px 12px;border-radius:8px;background:var(--navy3);border:1px solid var(--border);font-size:11px;display:flex;align-items:center;gap:8px;}
.user-avatar{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.ua-principal{background:linear-gradient(135deg,#f59e0b,#d97706);}
.ua-admin{background:linear-gradient(135deg,#00d4aa,#0284c7);}
.ua-adviser{background:linear-gradient(135deg,#8b5cf6,#6d28d9);}
.user-info .un{font-weight:700;color:var(--text);}
.user-info .ur{color:var(--muted);font-size:10px;font-family:var(--mono);}
.logout-link{margin-left:auto;cursor:pointer;color:var(--muted);font-size:14px;}
.logout-link:hover{color:var(--red);}
nav{flex:1;padding:12px 0;}
.nav-group{padding:10px 14px 4px;font-size:9px;font-weight:700;color:rgba(255,255,255,.3);letter-spacing:1.5px;text-transform:uppercase;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 16px;color:rgba(255,255,255,.6);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;border-left:3px solid transparent;text-decoration:none;}
.nav-item:hover{background:var(--navy3);color:var(--text);}
.nav-item.active{background:var(--teal3);border-left-color:var(--teal);color:var(--teal);font-weight:700;}
.nav-item.hidden{display:none;}
.nav-badge{margin-left:auto;background:var(--red);color:#fff;padding:1px 6px;border-radius:8px;font-size:10px;font-weight:700;}
.sb-bottom{padding:14px 16px;border-top:1px solid var(--border);font-family:var(--mono);}
.sb-clock{font-size:22px;font-weight:800;color:var(--teal);}
.sb-date{font-size:10px;color:var(--muted);margin-top:2px;}
.sb-refresh{font-size:10px;color:rgba(255,255,255,.3);margin-top:4px;}
.main{margin-left:230px;flex:1;display:flex;flex-direction:column;min-width:0;}
.topbar{background:rgba(17,24,39,.95);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.topbar-left h2{font-size:20px;font-weight:800;color:var(--text);}
.topbar-left p{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:2px;}
.topbar-right{display:flex;gap:10px;align-items:center;}
.btn{padding:8px 16px;border:none;border-radius:8px;font-size:13px;font-weight:700;cursor:pointer;font-family:var(--sans);display:inline-flex;align-items:center;gap:6px;transition:all .18s;text-decoration:none;}
.btn-teal{background:var(--teal);color:var(--navy);} .btn-teal:hover{background:var(--teal2);box-shadow:var(--glow-teal);}
.btn-ghost{background:var(--navy3);color:var(--muted);border:1px solid var(--border);} .btn-ghost:hover{color:var(--text);background:var(--navy4);}
.btn-amber{background:var(--amber);color:var(--navy);}
.btn-red{background:var(--red);color:#fff;}
.btn-sm{padding:6px 12px;font-size:12px;}
.content{padding:20px 24px 60px;}
.page{display:none;} .page.active{display:block;}
.role-bar{display:flex;gap:8px;margin-bottom:18px;align-items:center;padding:12px 16px;background:var(--navy2);border:1px solid var(--border);border-radius:var(--radius);}
.role-bar label{font-size:11px;color:var(--muted);font-weight:700;font-family:var(--mono);}
.role-pill{padding:5px 14px;border-radius:20px;border:1.5px solid var(--border);background:transparent;font-size:12px;font-weight:700;cursor:pointer;color:var(--muted);font-family:var(--sans);transition:all .15s;}
.role-pill.active{background:var(--teal);color:var(--navy);border-color:var(--teal);}
.filter-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:18px;align-items:center;}
.filter-bar select,.filter-bar input{padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:12px;background:var(--navy2);color:var(--text);outline:none;font-family:var(--mono);transition:border .15s;}
.filter-bar select:focus,.filter-bar input:focus{border-color:var(--teal);}
.filter-bar select option{background:var(--navy2);}
.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(155px,1fr));gap:12px;margin-bottom:20px;}
.stat{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px;position:relative;overflow:hidden;transition:all .2s;}
.stat:hover{border-color:rgba(255,255,255,.14);}
.stat::after{content:attr(data-icon);position:absolute;right:14px;top:10px;font-size:32px;opacity:.08;pointer-events:none;}
.stat .num{font-size:34px;font-weight:900;line-height:1;font-family:var(--mono);}
.stat .lbl{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin-top:4px;}
.stat .delta{font-size:11px;margin-top:4px;font-family:var(--mono);}
.stat .bar{height:3px;border-radius:2px;margin-top:10px;background:var(--border);}
.stat .bar-fill{height:100%;border-radius:2px;}
.s-total .num{color:var(--blue);} .s-total .bar-fill{background:var(--blue);}
.s-present .num{color:var(--green);} .s-present .bar-fill{background:var(--green);}
.s-late .num{color:var(--amber);} .s-late .bar-fill{background:var(--amber);}
.s-vlate .num{color:var(--purple);} .s-vlate .bar-fill{background:var(--purple);}
.s-absent .num{color:var(--red);} .s-absent .bar-fill{background:var(--red);}
.s-rate .num{color:var(--teal);} .s-rate .bar-fill{background:var(--teal);}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px;}
.grid-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px;}
@media(max-width:900px){.grid-2,.grid-3{grid-template-columns:1fr;}}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:16px;}
.card-head{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:8px;font-weight:700;font-size:13px;color:var(--teal);font-family:var(--mono);background:rgba(0,212,170,.03);}
.card-tag{font-size:10px;font-weight:700;padding:2px 8px;border-radius:8px;background:var(--teal3);color:var(--teal);}
.heatmap{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:8px;padding:14px;}
.heat-cell{border-radius:8px;padding:10px 8px;text-align:center;border:1px solid var(--border);transition:all .2s;cursor:default;}
.heat-cell:hover{transform:scale(1.04);z-index:2;}
.heat-cell .hc-sec{font-size:10px;font-weight:700;color:var(--muted);margin-bottom:4px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.heat-cell .hc-rate{font-size:18px;font-weight:900;font-family:var(--mono);}
.heat-cell .hc-cnt{font-size:9px;color:var(--muted);margin-top:2px;font-family:var(--mono);}
.h-high{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.3);} .h-high .hc-rate{color:var(--green);}
.h-med{background:rgba(245,158,11,.10);border-color:rgba(245,158,11,.25);} .h-med .hc-rate{color:var(--amber);}
.h-low{background:rgba(239,68,68,.10);border-color:rgba(239,68,68,.25);} .h-low .hc-rate{color:var(--red);}
.tbl-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th,td{padding:10px 14px;text-align:left;border-bottom:1px solid var(--border);}
th{background:rgba(255,255,255,.02);font-weight:700;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;font-family:var(--mono);}
tr:last-child td{border-bottom:none;}
tbody tr:hover td{background:rgba(255,255,255,.02);}
td.mono{font-family:var(--mono);}
.chip{display:inline-flex;align-items:center;gap:4px;padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;font-family:var(--mono);}
.c-present{background:var(--green2);color:var(--green);}
.c-late{background:var(--amber2);color:var(--amber);}
.c-vlate{background:var(--purple2);color:var(--purple);}
.c-absent{background:var(--red2);color:var(--red);}
.c-exit{background:var(--blue2);color:var(--blue);}
.c-high{background:var(--red2);color:var(--red);border:1px solid rgba(239,68,68,.3);}
.c-med{background:var(--amber2);color:var(--amber);border:1px solid rgba(245,158,11,.3);}
.c-low{background:var(--green2);color:var(--green);border:1px solid rgba(16,185,129,.3);}
.c-crit{background:rgba(220,38,38,.2);color:#fca5a5;border:1px solid rgba(239,68,68,.4);}
.risk-entry{display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--border);transition:background .15s;}
.risk-entry:last-child{border:none;}
.risk-entry:hover{background:rgba(255,255,255,.02);}
.risk-avatar{width:36px;height:36px;border-radius:50%;background:var(--navy3);border:2px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
.risk-info{flex:1;min-width:0;}
.risk-name{font-weight:700;font-size:13px;}
.risk-meta{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:2px;}
.risk-bar-wrap{width:80px;height:6px;background:var(--border);border-radius:3px;flex-shrink:0;}
.risk-bar-fill{height:100%;border-radius:3px;transition:width .5s;}
.risk-score{font-family:var(--mono);font-weight:800;font-size:13px;width:36px;text-align:right;flex-shrink:0;}
.risk-action{flex-shrink:0;}
.sf2-controls{display:flex;gap:10px;flex-wrap:wrap;padding:14px 16px;border-bottom:1px solid var(--border);}
.sf2-controls select,.sf2-controls input{padding:8px 12px;border:1px solid var(--border);border-radius:8px;font-size:12px;background:var(--navy2);color:var(--text);outline:none;font-family:var(--mono);}
.sf2-controls select:focus{border-color:var(--teal);}
.sf2-controls select option{background:var(--navy2);}
#sf2-preview{padding:20px;color:#000;background:#fff;font-family:'Times New Roman',serif;font-size:11px;min-height:300px;transition:opacity .3s;}
#sf2-preview.loading{display:flex;align-items:center;justify-content:center;color:#666;font-family:sans-serif;background:var(--navy2);min-height:200px;}
.sf2-header{text-align:center;margin-bottom:10px;}
.sf2-header h1{font-size:13px;font-weight:bold;margin:4px 0;}
.sf2-meta{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid #000;margin-bottom:6px;}
.sf2-mc{padding:4px 7px;border-right:1px solid #000;font-size:10px;}
.sf2-mc:last-child{border:none;}
.sf2-ml{font-weight:bold;font-size:9px;display:block;margin-bottom:2px;}
.sf2-mv{border-bottom:1px solid #000;min-height:15px;}
.sf2-tbl{width:100%;border-collapse:collapse;font-size:9px;}
.sf2-tbl th,.sf2-tbl td{border:1px solid #000;padding:2px 3px;text-align:center;}
.sf2-tbl th{background:#e8e8e8;font-size:8px;font-weight:bold;}
.sf2-tbl .nc{text-align:left;padding-left:4px;}
.sf2-tbl .tot{font-weight:bold;background:#f0f0f0;}
.sf2-sig{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:16px;}
.sf2-sig .ss{text-align:center;}
.sf2-sig .sl{border-bottom:1px solid #000;min-height:26px;margin-bottom:3px;}
.sf2-sig .sn{font-weight:bold;font-size:10px;}
.sf2-sig .st{font-size:9px;}
.sf2-legend{margin-top:7px;font-size:9px;display:flex;gap:12px;flex-wrap:wrap;}
.excuse-card{padding:13px 16px;border-bottom:1px solid var(--border);display:flex;gap:12px;align-items:flex-start;}
.excuse-card:last-child{border:none;}
.exc-icon{font-size:24px;flex-shrink:0;}
.exc-info{flex:1;}
.exc-student{font-weight:700;}
.exc-reason{font-size:12px;color:var(--muted);margin-top:2px;}
.exc-meta{font-size:10px;color:var(--muted);font-family:var(--mono);margin-top:4px;}
.exc-actions{display:flex;gap:6px;flex-shrink:0;}
.exc-btn{padding:5px 10px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;border:none;font-family:var(--sans);}
.exc-approve{background:var(--green2);color:var(--green);}
.exc-reject{background:var(--red2);color:var(--red);}
.tabs{display:flex;border-bottom:1px solid var(--border);padding:0 16px;background:rgba(0,0,0,.2);}
.tab{padding:11px 16px;font-size:13px;font-weight:700;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .15s;white-space:nowrap;}
.tab.active{color:var(--teal);border-bottom-color:var(--teal);}
.predict-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;padding:14px;}
.predict-card{background:var(--navy3);border:1px solid var(--border);border-radius:10px;padding:14px;}
.predict-card h4{font-size:12px;font-weight:700;color:var(--muted);font-family:var(--mono);margin-bottom:10px;text-transform:uppercase;letter-spacing:.5px;}
.intervention-tag{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;margin:3px;}
.int-parent{background:rgba(59,130,246,.15);color:var(--blue);}
.int-guidance{background:rgba(139,92,246,.15);color:var(--purple);}
.int-home{background:rgba(245,158,11,.15);color:var(--amber);}
.int-contract{background:rgba(239,68,68,.15);color:var(--red);}
.chart-wrap{padding:16px;}
.live-badge{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:700;font-family:var(--mono);color:var(--green);padding:3px 8px;border-radius:8px;background:var(--green2);}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
.live-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 1.4s ease-in-out infinite;}
.empty{padding:32px;text-align:center;color:var(--muted);font-family:var(--mono);font-size:12px;}
.empty .ei{font-size:40px;margin-bottom:10px;}

/* ── ENROLL PANEL ── */
.enroll-form{padding:16px;display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.enroll-form .ef{display:flex;flex-direction:column;gap:5px;}
.enroll-form .ef.full{grid-column:1/-1;}
.enroll-form label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;}
.enroll-form input,.enroll-form select{padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;background:var(--navy3);color:var(--text);font-size:13px;outline:none;}
.enroll-form input:focus,.enroll-form select:focus{border-color:var(--teal);}
.enroll-actions{padding:0 16px 16px;display:flex;gap:10px;}
#enroll-status{margin:0 16px 12px;padding:9px 13px;border-radius:7px;font-size:12px;font-weight:600;display:none;}
.es-ok{background:var(--green2);color:var(--green);display:block!important;}
.es-err{background:var(--red2);color:var(--red);display:block!important;}

@media print{
  .sidebar,.topbar,.role-bar,.filter-bar,.topbar-right,.tabs,#login-screen,
  #page-dashboard,#page-risk,#page-excuse,#page-predictive,#page-enroll,
  .sf2-controls .btn{display:none!important;}
  .main{margin:0;}
  body{background:#fff;color:#000;}
  #sf2-preview{padding:0;background:#fff;}
  .page{display:block!important;}
  #page-sf2,#page-summary{display:block!important;}
  @page{size:A4 landscape;margin:10mm;}
}
</style>
</head>
<body>

<!-- ══════════════ LOGIN SCREEN ══════════════ -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">🎓</div>
    <h2>Project LEAD</h2>
    <p>JALIOBONG NHS · SECURE ACCESS</p>

    <div class="login-error" id="login-error"></div>

    <div class="login-field">
      <label>Username</label>
      <input type="text" id="login-user" placeholder="e.g. principal" onkeydown="if(event.key==='Enter')document.getElementById('login-pass').focus()">
    </div>
    <div class="login-field">
      <label>Password</label>
      <input type="password" id="login-pass" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()">
    </div>

    <button class="login-btn" id="login-btn" onclick="doLogin()">Sign In</button>

    <div class="login-roles">
      <span class="role-tag">👑 Principal</span>
      <span class="role-tag">🔧 Admin</span>
      <span class="role-tag">📚 Adviser</span>
    </div>
  </div>
</div>

<!-- ══════════════ MAIN APP (hidden until login) ══════════════ -->
<div class="shell" id="app-shell" style="display:none">

<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-icon">🎓</div>
    <div>
      <div class="sb-name">Project LEAD</div>
      <div class="sb-sub">v2.1 SMART ATTENDANCE</div>
    </div>
  </div>

