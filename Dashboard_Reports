function makeSummary() {
  const mo = parseInt(document.getElementById("sum-month").value);
  let tp=0,tl=0,tvl=0,ta=0,te=0;
  const advMap = {}; (dashData.advisers||[]).forEach(a => advMap[a.section] = a);

  const rows = (dashData.sections||[])
    .filter(s => currentSection === "all" || s.section === currentSection)
    .map(sec => {
      const a = advMap[sec.section] || {};
      const p=a.present||0, l=a.late||0, vl=a.veryLate||0, ab=a.absent||0;
      const tot=p+l+vl+ab, rate=tot?Math.round((p+l)/tot*100):0;
      const rc=rate>=90?"var(--green)":rate>=75?"var(--amber)":"var(--red)";
      tp+=p;tl+=l;tvl+=vl;ta+=ab;te+=sec.enrolled;
      return `<tr><td><strong>${sec.section}</strong></td><td>Grade ${sec.grade}</td><td style="font-size:12px">${sec.adviser}</td><td class="mono">${sec.enrolled}</td><td style="color:var(--green);font-weight:700;font-family:var(--mono)">${p}</td><td style="color:var(--amber);font-family:var(--mono)">${l}</td><td style="color:var(--purple);font-family:var(--mono)">${vl}</td><td style="color:var(--red);font-family:var(--mono)">${ab}</td><td><strong style="color:${rc};font-family:var(--mono)">${rate}%</strong></td></tr>`;
    });

  const gt=tp+tl+tvl+ta, gr=gt?Math.round((tp+tl)/gt*100):0;
  rows.push(`<tr style="background:var(--navy3);font-weight:800;border-top:2px solid var(--border)"><td colspan="3">GRAND TOTAL — ${MONTHS[mo]}</td><td class="mono">${te}</td><td style="color:var(--green);font-family:var(--mono)">${tp}</td><td style="color:var(--amber);font-family:var(--mono)">${tl}</td><td style="color:var(--purple);font-family:var(--mono)">${tvl}</td><td style="color:var(--red);font-family:var(--mono)">${ta}</td><td style="font-family:var(--mono);font-weight:800">${gr}%</td></tr>`);

  document.getElementById("sum-tbody").innerHTML = rows.join("") || `<tr><td colspan="9" class="empty">No sections enrolled yet</td></tr>`;
}
</script>
</body>
</html>
