function submitEnrollment() {
  const data = {
    id: document.getElementById("en-id").value.trim(),
    lrn: document.getElementById("en-lrn").value.trim(),
    sex: document.getElementById("en-sex").value,
    lastName: document.getElementById("en-last").value.trim(),
    firstName: document.getElementById("en-first").value.trim(),
    middleName: document.getElementById("en-middle").value.trim(),
    grade: document.getElementById("en-grade").value,
    section: document.getElementById("en-section").value.trim(),
    parentPhone: document.getElementById("en-phone").value.trim(),
    parentName: document.getElementById("en-parentname").value.trim(),
    parentPsid: document.getElementById("en-psid").value.trim(),
    adviserEmail: document.getElementById("en-adviser").value.trim()
  };

  if (!data.id || !data.lastName || !data.firstName || !data.grade || !data.section) {
    showEnrollStatus("⚠️ Fill in all required fields (*)", false);
    return;
  }

  showEnrollStatus("⏳ Saving…", true);

  fetch(CONFIG.APPS_SCRIPT_URL, {
    method: "POST",
    headers: { "Content-Type": "text/plain" },
    body: JSON.stringify({ action: "enroll", data, token: session.token })
  })
  .then(r => r.json())
  .then(res => {
    if (res.status === "success" && res.data && res.data.success) {
      showEnrollStatus("✅ Student enrolled and QR generated!", true);
      document.getElementById("qr-result-card").style.display = "block";
      document.getElementById("qr-result-img").src = res.data.qrUrl;
      clearEnrollForm();
      loadAll();
    } else {
      showEnrollStatus("❌ " + ((res.data && res.data.message) || res.message || "Failed to save"), false);
    }
  })
  .catch(() => showEnrollStatus("❌ Connection error", false));
}

