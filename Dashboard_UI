    <td><span class="chip ${pm[r.status]||"cp"}">${r.status}</span></td>
    <td style="font-family:var(--mono);font-size:11px;color:var(--muted)">${r.time}</td>
  </tr>`).join("")||`<tr><td colspan="5" class="empty-msg">No scans today</td></tr>`;
}

function renderHeatmap(){
  const advMap={};(dashData.advisers||[]).forEach(a=>advMap[a.section]=a);
  document.getElementById("heatmap-grid").innerHTML=(dashData.sections||[])
    .filter(s=>curSec==="all"||s.section===curSec)
    .map(sec=>{
      const a=advMap[sec.section]||{};
      const tot=(a.present||0)+(a.late||0)+(a.veryLate||0)+(a.absent||0);
      const rate=tot?Math.round((a.present||0)/tot*100):0;
      const cls=rate>=90?"hh":rate>=75?"hm":"hl";
      return`<div class="hc ${cls}" title="${sec.adviser}"><div class="hs">${sec.section}</div><div class="hr">${rate}%</div><div class="hcnt">${a.present||0}/${tot||sec.enrolled}</div></div>`;
    }).join("")||`<div class="empty-msg">No sections found</div>`;
}

function renderRisk(){
  const profiles=riskData?.profiles||[];
  const flagged=profiles.filter(r=>r.ratio>=45).length;
  document.getElementById("risk-bdg").textContent=flagged;
  document.getElementById("risk-tag").textContent=flagged+" FLAGGED";
  const lvl=r=>r.ratio>=60?"CRITICAL":r.ratio>=45?"HIGH":r.ratio>=30?"MEDIUM":"LOW";
  const lc={"CRITICAL":"ca","HIGH":"ca","MEDIUM":"cl","LOW":"cp"};
  const bc={"CRITICAL":"#ef4444","HIGH":"#f87171","MEDIUM":"#f59e0b","LOW":"#10b981"};
  document.getElementById("risk-list").innerHTML=profiles.map(r=>`
    <div class="risk-entry">
      <div style="font-size:28px">⚠️</div>
      <div class="risk-info"><div class="risk-name">${r.name}</div><div class="risk-meta">${r.section||"—"} · ${r.absences} abs · ${r.lates} lates · ${r.ratio}% ratio</div></div>
      <div class="risk-bw"><div class="risk-bf" style="width:${r.ratio}%;background:${bc[lvl(r)]}"></div></div>
      <div class="risk-score" style="color:${bc[lvl(r)]}">${r.ratio}</div>
      <span class="chip ${lc[lvl(r)]}">${lvl(r)}</span>
    </div>`).join("")||`<div class="empty-msg">✅ No high-risk students detected</div>`;
}

