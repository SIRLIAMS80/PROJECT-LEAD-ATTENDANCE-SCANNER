  document.getElementById("ua").className="ua "+cl;
  document.getElementById("un").textContent=session.fullName||"User";
  document.getElementById("ur").textContent=(session.role||"").toUpperCase()+" ACCESS";

  // Adviser: lock to their section
  if(session.role==="adviser"&&session.section){
    curSec=session.section;
    document.getElementById("f-section").value=session.section;
    document.getElementById("f-section").disabled=true;
    document.getElementById("f-grade").disabled=true;
  }

  // Init
  document.getElementById("f-date").value=new Date().toISOString().slice(0,10);
  document.getElementById("sf2-yr").value=new Date().getFullYear();
  const m2=new Date().getMonth()+1;
  document.getElementById("sf2-mo").value=m2;
  document.getElementById("sum-mo").value=m2;

  loadAll();
  setInterval(loadAll,CFG.REFRESH);
}

// Restore session on reload
(function(){ const s=sessionStorage.getItem("ls"); if(s){ session=JSON.parse(s); enterApp(); }})();

// ════════════════════════════════════
// DATA
// ════════════════════════════════════
async function apiFetch(action){
  if(IS_GAS){
    return new Promise((res,rej)=>{
      const fnMap={dashboard:"getFullDashboardData",log:"getTodayAttendanceList",risk:"getAIRiskReport"};
      const fn=fnMap[action];
      if(!fn){res({});return;}
      google.script.run.withSuccessHandler(res).withFailureHandler(rej)[fn]();
    });
  }
  const r=await fetch(`${CFG.URL}?action=${action}`,{redirect:"follow"});
  const j=await r.json();
  return j.data||j;
}

async function loadAll(){
  try{
    [dashData,logData,riskData]=await Promise.all([apiFetch("dashboard"),apiFetch("log"),apiFetch("risk")]);
    // Populate section dropdowns
    const secs=(dashData.sections||[]).map(s=>s.section);
    ["f-section","sf2-sec"].forEach(id=>{
      const el=document.getElementById(id);
      if(el.options.length<=1&&secs.length){
        secs.forEach(s=>{const o=new Option(s,s);el.add(o);});
      }
    });
    if(riskData&&riskData.profiles) document.getElementById("risk-bdg").textContent=riskData.profiles.filter(r=>r.ratio>=45).length;
    renderStats(); renderGrade(); renderAdviser(); renderTrend(); renderSessions(); renderLog(); renderHeatmap();
    document.getElementById("sb-sync").textContent="Last sync: "+new Date().toLocaleTimeString("en-PH",{hour:"2-digit",minute:"2-digit"});
  }catch(e){ console.error("loadAll:",e); }
}

function applyF(){ curSec=document.getElementById("f-section").value; loadAll(); }
function clearF(){
  if(session?.role!=="adviser"){ document.getElementById("f-section").value="all"; document.getElementById("f-grade").value="all"; curSec="all"; }
  document.getElementById("f-date").value=new Date().toISOString().slice(0,10);
  loadAll();
}

// ════════════════════════════════════
// RENDER FUNCTIONS
// ════════════════════════════════════
function renderStats(){
  const t=dashData.totals||{};
  const p=t.present||0,l=t.late||0,vl=t.veryLate||0,a=t.absent||0;
  const tot=p+l+vl+a,rate=tot?Math.round((p+l)/tot*100):0;
  document.getElementById("st-tot").textContent=tot;
  document.getElementById("st-pre").textContent=p;
  document.getElementById("st-lat").textContent=l;
  document.getElementById("st-vl").textContent=vl;
  document.getElementById("st-abs").textContent=a;
  document.getElementById("st-rate").textContent=rate+"%";
  const bfills={tot:100,pre:tot?p/tot*100:0,lat:tot?l/tot*100:0,vl:tot?vl/tot*100:0,abs:tot?a/tot*100:0,rate};
  Object.entries(bfills).forEach(([k,v])=>{const el=document.getElementById("bf-"+k);if(el)el.style.width=Math.min(v,100)+"%";});
}

function renderGrade(){
  const rows=(dashData.gradeLevel||[]).filter(g=>curSec==="all"||true).map(g=>{
    const tot=(g.present||0)+(g.late||0)+(g.veryLate||0)+(g.absent||0);
    const rate=tot?Math.round(((g.present||0)+(g.late||0))/tot*100):0;
    const rc=rate>=90?"var(--green)":rate>=75?"var(--amber)":"var(--red)";
    return`<tr><td><strong>Grade ${g.grade}</strong></td><td style="color:var(--green);font-weight:700">${g.present||0}</td><td style="color:var(--amber)">${g.late||0}</td><td style="color:var(--red)">${g.absent||0}</td><td><strong style="color:${rc};font-family:var(--mono)">${rate}%</strong></td></tr>`;
  });
  document.getElementById("grade-tbody").innerHTML=rows.join("")||`<tr><td colspan="5" class="empty-msg">No data today</td></tr>`;
}

function renderAdviser(){
  const rows=(dashData.advisers||[]).filter(a=>curSec==="all"||a.section===curSec).map(a=>{
    const tot=(a.present||0)+(a.late||0)+(a.veryLate||0)+(a.absent||0);
    const rate=tot?Math.round(((a.present||0)+(a.late||0))/tot*100):0;
    const rc=rate>=90?"var(--green)":rate>=75?"var(--amber)":"var(--red)";
    return`<tr><td><strong>${a.adviser}</strong></td><td style="font-family:var(--mono);font-size:11px">${a.section}</td><td style="color:var(--green);font-weight:700">${a.present||0}</td><td><strong style="color:${rc};font-family:var(--mono)">${rate}%</strong></td></tr>`;
  });
  document.getElementById("adv-tbody").innerHTML=rows.join("")||`<tr><td colspan="4" class="empty-msg">No advisers found</td></tr>`;
}

function renderTrend(){
  const t=dashData.weeklyTrend||{days:[],present:[],absent:[],late:[]};
  if(!t.days.length){document.getElementById("trend-chart").innerHTML=`<div class="empty-msg">No trend data yet</div>`;return;}
  const W=660,H=160,pL=40,pB=26,pT=12,pR=12;
  const iW=W-pL-pR,iH=H-pB-pT;
  const mx=Math.max(1,...t.present,...t.absent,...t.late)*1.15;
  const gp=t.days.length>1?iW/(t.days.length-1):0;
  function poly(arr,c){
    const p=arr.map((v,i)=>`${pL+i*gp},${pT+iH-(v/mx)*iH}`);
    return`<polygon points="${p.join(" ")} ${pL+gp*(arr.length-1)},${pT+iH} ${pL},${pT+iH}" fill="${c}" opacity=".1"/>
    <polyline points="${p.join(" ")}" fill="none" stroke="${c}" stroke-width="2.5" stroke-linejoin="round"/>`;
  }
  let svg=`<svg viewBox="0 0 ${W} ${H}" style="width:100%;height:160px">`;
  for(let i=0;i<=4;i++){const y=pT+(iH/4)*i;svg+=`<line x1="${pL}" y1="${y}" x2="${W-pR}" y2="${y}" stroke="rgba(255,255,255,.06)"/><text x="${pL-5}" y="${y+4}" text-anchor="end" font-size="9" fill="#94a3b8">${Math.round(mx-mx/4*i)}</text>`;}
  svg+=poly(t.present,"#10b981")+poly(t.late,"#f59e0b")+poly(t.absent,"#ef4444");
  t.days.forEach((d,i)=>{const x=pL+i*gp,yp=pT+iH-(t.present[i]/mx)*iH,ya=pT+iH-(t.absent[i]/mx)*iH;svg+=`<circle cx="${x}" cy="${yp}" r="3.5" fill="#10b981"/><circle cx="${x}" cy="${ya}" r="3.5" fill="#ef4444"/><text x="${x}" y="${H-4}" text-anchor="middle" font-size="9" fill="#94a3b8">${d}</text>`;});
  svg+=`</svg><div style="display:flex;gap:14px;padding:2px 4px;font-size:11px;font-family:var(--mono)">
    <span style="color:var(--green)">▬ Present</span><span style="color:var(--amber)">▬ Late</span><span style="color:var(--red)">▬ Absent</span></div>`;
  document.getElementById("trend-chart").innerHTML=svg;
}

function renderSessions(){
  const s=dashData.sessionSummary||{};
  const cards=[{k:"AM-IN",l:"AM Time-In",i:"🌅",t:"5:00–8:30 AM"},{k:"AM-OUT",l:"AM Time-Out",i:"☀️",t:"11:00 AM–12:30 PM"},{k:"PM-IN",l:"PM Time-In",i:"🌤",t:"12:00–1:30 PM"},{k:"PM-OUT",l:"PM Time-Out",i:"🌆",t:"4:00–5:30 PM"}];
  document.getElementById("session-grid").innerHTML=cards.map(c=>{
    const cnt=s[c.k]||0;
    return`<div style="background:var(--navy3);border:1px solid var(--border);border-radius:9px;padding:12px;text-align:center">
      <div style="font-size:22px;margin-bottom:5px">${c.i}</div>
      <div style="font-size:11px;font-weight:700">${c.l}</div>
      <div style="font-size:9px;color:var(--muted);font-family:var(--mono);margin:4px 0 8px">${c.t}</div>
      <div style="font-size:26px;font-weight:900;color:var(--teal);font-family:var(--mono)">${cnt}</div>
    </div>`;
  }).join("");
}

function renderLog(){
  const pm={"Present":"cp","Late":"cl","Very Late":"cv","Absent":"ca","Campus Exit":"ce","PM PRESENT":"cp","LATE PM RETURN":"cl","EARLY OUT":"cl","EARLY DISMISSAL":"cl"};
  const rows=(Array.isArray(logData)?logData:[]).filter(r=>curSec==="all"||r.section===curSec);
  document.getElementById("log-tbody").innerHTML=rows.map(r=>`<tr>
