// ════════════════════════════════════
// AUTH — works for BOTH Apps Script and GitHub Pages
// ════════════════════════════════════
async function sha256client(str){
  const buf=await crypto.subtle.digest("SHA-256",new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,"0")).join("");
}

async function doLogin(){
  const user = document.getElementById("login-u").value.trim();
  const pass = document.getElementById("login-p").value;
  const errEl = document.getElementById("login-err");
  const btn   = document.getElementById("login-btn");

  errEl.className = "login-err";
  if(!user||!pass){ errEl.textContent="⚠️ Enter username and password."; errEl.className="login-err show"; return; }

  btn.disabled=true; btn.textContent="Signing in…";

  // Pre-hash so password never travels in plain text
  const hashed = await sha256client(pass);

  if(IS_GAS){
    // Inside Apps Script modal — use google.script.run
    google.script.run
      .withSuccessHandler(r=>{ btn.disabled=false; btn.textContent="Sign In"; if(r.success){session=r;sessionStorage.setItem("ls",JSON.stringify(r));enterApp();}else{errEl.textContent="❌ "+r.message;errEl.className="login-err show";}})
      .withFailureHandler(e=>{ btn.disabled=false; btn.textContent="Sign In"; errEl.textContent="❌ "+e.message; errEl.className="login-err show";})
      .loginUser(user, hashed);
  } else {
    // GitHub Pages — fetch
    try{
      const url = `${CFG.URL}?action=login&u=${encodeURIComponent(user)}&pw=${encodeURIComponent(hashed)}`;
      const res  = await fetch(url,{method:"GET",redirect:"follow"});
      if(!res.ok) throw new Error("HTTP "+res.status);
      const json = await res.json();
      const r    = json.data || json;
      btn.disabled=false; btn.textContent="Sign In";
      if(r.success){ session=r; sessionStorage.setItem("ls",JSON.stringify(r)); enterApp(); }
      else{ errEl.textContent="❌ "+(r.message||"Login failed."); errEl.className="login-err show"; }
    }catch(e){
      btn.disabled=false; btn.textContent="Sign In";
      errEl.textContent="❌ Connection error: "+e.message+"\n\n→ Check Apps Script URL in CFG.URL\n→ Must be deployed as 'Anyone' access\n→ Create a NEW deployment after code changes";
      errEl.className="login-err show";
    }
  }
}

function doLogout(){
  sessionStorage.removeItem("ls"); session=null;
