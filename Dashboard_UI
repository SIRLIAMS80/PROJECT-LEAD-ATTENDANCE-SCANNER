<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Project LEAD — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0a0f1e;--navy2:#111827;--navy3:#1a2235;--navy4:#242f45;
  --teal:#00d4aa;--teal2:#00b894;--teal3:rgba(0,212,170,.12);
  --amber:#f59e0b;--amber2:rgba(245,158,11,.12);
  --red:#ef4444;--red2:rgba(239,68,68,.12);
  --green:#10b981;--green2:rgba(16,185,129,.12);
  --blue:#3b82f6;--blue2:rgba(59,130,246,.12);
  --purple:#8b5cf6;--purple2:rgba(139,92,246,.12);
  --text:#f1f5f9;--muted:#94a3b8;--border:rgba(255,255,255,.07);
  --card:rgba(255,255,255,.03);--radius:12px;
  --mono:'JetBrains Mono',monospace;--sans:'Inter',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:var(--sans);background:var(--navy);color:var(--text);min-height:100vh;font-size:14px;}

/* LOGIN */
#login-screen{position:fixed;inset:0;background:var(--navy);z-index:1000;display:flex;align-items:center;justify-content:center;}
.login-box{width:380px;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:18px;padding:36px 30px;backdrop-filter:blur(20px);box-shadow:0 20px 60px rgba(0,0,0,.6);}
.login-logo{width:58px;height:58px;border-radius:15px;background:linear-gradient(135deg,var(--teal),var(--blue));display:flex;align-items:center;justify-content:center;font-size:28px;margin:0 auto 16px;}
.login-box h2{text-align:center;font-size:20px;font-weight:900;}
.login-box .sub{text-align:center;font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:4px;margin-bottom:26px;letter-spacing:.5px;}
.lf{margin-bottom:14px;}
.lf label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:5px;}
.lf input{width:100%;padding:11px 14px;border:1.5px solid var(--border);border-radius:9px;background:var(--navy3);color:var(--text);font-size:13px;outline:none;font-family:var(--sans);transition:border .2s;}
.lf input:focus{border-color:var(--teal);}
.login-btn{width:100%;padding:12px;border:none;border-radius:9px;background:linear-gradient(135deg,var(--teal),var(--teal2));color:var(--navy);font-size:14px;font-weight:900;cursor:pointer;margin-top:6px;transition:all .2s;}
.login-btn:hover:not(:disabled){transform:translateY(-1px);box-shadow:0 8px 20px rgba(0,212,170,.3);}
.login-btn:disabled{opacity:.5;cursor:not-allowed;}
.login-err{background:var(--red2);color:var(--red);border:1px solid rgba(239,68,68,.3);padding:10px 14px;border-radius:8px;font-size:12px;margin-bottom:14px;display:none;font-weight:600;line-height:1.4;}
.login-err.show{display:block;}
.role-pills{display:flex;gap:6px;justify-content:center;margin-top:18px;}
.rp{font-size:10px;font-family:var(--mono);color:var(--muted);background:var(--navy3);padding:4px 10px;border-radius:8px;border:1px solid var(--border);}

/* LAYOUT */
.shell{display:flex;min-height:100vh;}
.sidebar{width:230px;flex-shrink:0;background:var(--navy2);border-right:1px solid var(--border);position:fixed;top:0;bottom:0;left:0;z-index:100;display:flex;flex-direction:column;overflow-y:auto;}
.sb-brand{padding:20px 16px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;}
.sb-icon{width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,var(--teal),var(--blue));display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.sb-name{font-size:14px;font-weight:800;}
.sb-sub{font-size:9px;color:var(--muted);font-family:var(--mono);margin-top:1px;}
.sb-user{margin:10px 10px 0;padding:9px 12px;border-radius:8px;background:var(--navy3);border:1px solid var(--border);display:flex;align-items:center;gap:8px;}
.ua{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.ua-p{background:linear-gradient(135deg,#f59e0b,#d97706);}
.ua-a{background:linear-gradient(135deg,#00d4aa,#0284c7);}
.ua-v{background:linear-gradient(135deg,#8b5cf6,#6d28d9);}
.un{font-weight:700;font-size:12px;}
.ur{color:var(--muted);font-size:9px;font-family:var(--mono);}
.logout{margin-left:auto;cursor:pointer;color:var(--muted);font-size:15px;padding:2px 4px;}
.logout:hover{color:var(--red);}
nav{flex:1;padding:10px 0;}
.ng{padding:10px 14px 4px;font-size:9px;font-weight:700;color:rgba(255,255,255,.3);letter-spacing:1.5px;text-transform:uppercase;}
.ni{display:flex;align-items:center;gap:9px;padding:9px 15px;color:rgba(255,255,255,.6);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;border-left:3px solid transparent;}
.ni:hover{background:var(--navy3);color:var(--text);}
.ni.active{background:var(--teal3);border-left-color:var(--teal);color:var(--teal);font-weight:700;}
.ni.hidden{display:none;}
.nbadge{margin-left:auto;background:var(--red);color:#fff;padding:1px 6px;border-radius:8px;font-size:10px;font-weight:700;}
.sb-bottom{padding:14px 16px;border-top:1px solid var(--border);font-family:var(--mono);}
.sb-clock{font-size:21px;font-weight:800;color:var(--teal);}
.sb-date{font-size:10px;color:var(--muted);margin-top:2px;}
.sb-sync{font-size:9px;color:rgba(255,255,255,.3);margin-top:3px;}

.main{margin-left:230px;flex:1;display:flex;flex-direction:column;min-width:0;}
.topbar{background:rgba(17,24,39,.96);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);padding:14px 24px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:50;}
.topbar h2{font-size:19px;font-weight:800;}
.topbar p{font-size:11px;color:var(--muted);font-family:var(--mono);margin-top:2px;}
.topbar-r{display:flex;gap:10px;align-items:center;}

.btn{padding:8px 15px;border:none;border-radius:8px;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--sans);display:inline-flex;align-items:center;gap:5px;transition:all .18s;}
.btn-teal{background:var(--teal);color:var(--navy);}
.btn-teal:hover{background:var(--teal2);box-shadow:0 0 16px rgba(0,212,170,.25);}
.btn-ghost{background:var(--navy3);color:var(--muted);border:1px solid var(--border);}
.btn-ghost:hover{color:var(--text);background:var(--navy4);}
.btn-sm{padding:6px 11px;font-size:11px;}

.content{padding:18px 22px 60px;}
.page{display:none;}.page.active{display:block;}
.filter-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:16px;align-items:center;}
.filter-bar select,.filter-bar input{padding:8px 11px;border:1px solid var(--border);border-radius:8px;font-size:12px;background:var(--navy2);color:var(--text);outline:none;font-family:var(--mono);}
.filter-bar select:focus,.filter-bar input:focus{border-color:var(--teal);}
.filter-bar select option{background:var(--navy2);}

.stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:11px;margin-bottom:18px;}
.stat{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px;position:relative;overflow:hidden;}
.stat::after{content:attr(data-icon);position:absolute;right:12px;top:8px;font-size:28px;opacity:.08;pointer-events:none;}
.stat .num{font-size:32px;font-weight:900;line-height:1;font-family:var(--mono);}
.stat .lbl{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;margin-top:4px;}
.stat .bar{height:3px;border-radius:2px;margin-top:10px;background:var(--border);}
.stat .bf{height:100%;border-radius:2px;transition:width .5s;}
.s-total .num{color:var(--blue);}.s-total .bf{background:var(--blue);}
.s-present .num{color:var(--green);}.s-present .bf{background:var(--green);}
.s-late .num{color:var(--amber);}.s-late .bf{background:var(--amber);}
.s-vlate .num{color:var(--purple);}.s-vlate .bf{background:var(--purple);}
.s-absent .num{color:var(--red);}.s-absent .bf{background:var(--red);}
.s-rate .num{color:var(--teal);}.s-rate .bf{background:var(--teal);}

.grid2{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:14px;}
@media(max-width:900px){.grid2{grid-template-columns:1fr;}}
.card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:14px;}
.ch{padding:12px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:8px;font-weight:700;font-size:13px;color:var(--teal);font-family:var(--mono);background:rgba(0,212,170,.02);}
.ctag{font-size:10px;font-weight:700;padding:2px 7px;border-radius:7px;background:var(--teal3);color:var(--teal);}
.heatmap{display:grid;grid-template-columns:repeat(auto-fill,minmax(90px,1fr));gap:7px;padding:12px;}
.hc{border-radius:8px;padding:9px 7px;text-align:center;border:1px solid var(--border);transition:all .2s;cursor:default;}
.hc:hover{transform:scale(1.04);}
.hc .hs{font-size:10px;font-weight:700;color:var(--muted);margin-bottom:3px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.hc .hr{font-size:17px;font-weight:900;font-family:var(--mono);}
.hc .hcnt{font-size:9px;color:var(--muted);font-family:var(--mono);}
.hh{background:rgba(16,185,129,.12);border-color:rgba(16,185,129,.3);}.hh .hr{color:var(--green);}
.hm{background:rgba(245,158,11,.1);border-color:rgba(245,158,11,.25);}.hm .hr{color:var(--amber);}
.hl{background:rgba(239,68,68,.1);border-color:rgba(239,68,68,.25);}.hl .hr{color:var(--red);}
.tbl-wrap{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
th,td{padding:9px 13px;text-align:left;border-bottom:1px solid var(--border);}
th{background:rgba(255,255,255,.02);font-weight:700;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.7px;font-family:var(--mono);}
tr:last-child td{border-bottom:none;}
tbody tr:hover td{background:rgba(255,255,255,.02);}
.chip{display:inline-flex;align-items:center;gap:4px;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:700;font-family:var(--mono);}
.cp{background:var(--green2);color:var(--green);}
.cl{background:var(--amber2);color:var(--amber);}
.cv{background:var(--purple2);color:var(--purple);}
.ca{background:var(--red2);color:var(--red);}
.ce{background:var(--blue2);color:var(--blue);}
.chart-wrap{padding:14px;}
.live-badge{display:inline-flex;align-items:center;gap:5px;font-size:10px;font-weight:700;font-family:var(--mono);color:var(--green);padding:3px 8px;border-radius:7px;background:var(--green2);}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
.ldot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:blink 1.4s ease-in-out infinite;}
.empty-msg{padding:28px;text-align:center;color:var(--muted);font-size:12px;font-family:var(--mono);}
.risk-entry{display:flex;align-items:center;gap:11px;padding:11px 15px;border-bottom:1px solid var(--border);}
.risk-entry:last-child{border:none;}
.risk-info{flex:1;}
.risk-name{font-weight:700;font-size:13px;}
.risk-meta{font-size:10px;color:var(--muted);font-family:var(--mono);}
.risk-bw{width:80px;height:5px;background:var(--border);border-radius:3px;flex-shrink:0;}
.risk-bf{height:100%;border-radius:3px;}
.risk-score{font-family:var(--mono);font-weight:800;font-size:13px;width:34px;text-align:right;}
.enroll-grid{padding:16px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:11px;}
.ef{display:flex;flex-direction:column;gap:4px;}
.ef.full{grid-column:1/-1;}
.ef label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;}
.ef input,.ef select{padding:9px 12px;border:1.5px solid var(--border);border-radius:8px;background:var(--navy3);color:var(--text);font-size:13px;outline:none;}
.ef input:focus,.ef select:focus{border-color:var(--teal);}
.ef select option{background:var(--navy3);}
.enroll-actions{padding:0 16px 16px;display:flex;gap:9px;}
#enroll-status{margin:0 16px 12px;padding:9px 13px;border-radius:7px;font-size:12px;font-weight:600;display:none;}
.es-ok{background:var(--green2);color:var(--green);display:block!important;}
.es-err{background:var(--red2);color:var(--red);display:block!important;}
.sf2-ctrl{display:flex;gap:9px;flex-wrap:wrap;padding:13px 15px;border-bottom:1px solid var(--border);}
.sf2-ctrl select{padding:8px 11px;border:1px solid var(--border);border-radius:7px;font-size:12px;background:var(--navy2);color:var(--text);outline:none;font-family:var(--mono);}
.sf2-ctrl select option{background:var(--navy2);}
#sf2-prev{padding:18px;color:#000;background:#fff;font-family:'Times New Roman',serif;font-size:11px;min-height:280px;}
#sf2-prev.loading{display:flex;align-items:center;justify-content:center;color:#666;font-family:sans-serif;background:var(--navy2);min-height:200px;}
.sf2-h{text-align:center;margin-bottom:10px;}
.sf2-h h1{font-size:13px;font-weight:bold;margin:4px 0;}
.sf2-meta{display:grid;grid-template-columns:repeat(3,1fr);border:1px solid #000;margin-bottom:6px;}
.sf2-mc{padding:4px 7px;border-right:1px solid #000;font-size:10px;}
.sf2-mc:last-child{border:none;}
.sf2-ml{font-weight:bold;font-size:9px;display:block;}
.sf2-mv{border-bottom:1px solid #000;min-height:15px;}
.sf2-tbl{width:100%;border-collapse:collapse;font-size:9px;}
.sf2-tbl th,.sf2-tbl td{border:1px solid #000;padding:2px 3px;text-align:center;}
.sf2-tbl th{background:#e8e8e8;font-size:8px;font-weight:bold;}
.sf2-sig{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:14px;}
.sf2-sig .ss{text-align:center;}
.sf2-sig .sl{border-bottom:1px solid #000;min-height:24px;margin-bottom:3px;}
.sf2-sig .sn{font-weight:bold;font-size:10px;}
.sf2-sig .st{font-size:9px;}
.tabs{display:flex;border-bottom:1px solid var(--border);padding:0 15px;background:rgba(0,0,0,.2);}
.tab{padding:10px 14px;font-size:13px;font-weight:700;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;margin-bottom:-1px;}
.tab.active{color:var(--teal);border-bottom-color:var(--teal);}
@media print{
  .sidebar,.topbar,.filter-bar,#login-screen,.topbar-r,.tabs,.sf2-ctrl .btn{display:none!important;}
  .main{margin:0;}
  body{background:#fff;color:#000;}
  #sf2-prev{padding:0;background:#fff;}
  .page{display:block!important;}
  #page-sf2,#page-summary{display:block!important;}
  @page{size:A4 landscape;margin:10mm;}
}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">🎓</div>
    <h2>Project LEAD</h2>
    <div class="sub">JALIOBONG NHS · SECURE ACCESS</div>
    <div class="login-err" id="login-err"></div>
    <div class="lf"><label>Username</label><input type="text" id="login-u" placeholder="principal / admin / adviser1" onkeydown="if(event.key==='Enter')document.getElementById('login-p').focus()"></div>
    <div class="lf"><label>Password</label><input type="password" id="login-p" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()"></div>
    <button class="login-btn" id="login-btn" onclick="doLogin()">Sign In</button>
    <div class="role-pills"><span class="rp">👑 Principal</span><span class="rp">🔧 Admin</span><span class="rp">📚 Adviser</span></div>
  </div>
</div>

<!-- APP SHELL -->
<div class="shell" id="app" style="display:none">
<aside class="sidebar">
  <div class="sb-brand">
    <div class="sb-icon">🎓</div>
    <div><div class="sb-name">Project LEAD</div><div class="sb-sub">v2.1 SMART ATTENDANCE</div></div>
  </div>
  <div class="sb-user">
    <div class="ua" id="ua">👑</div>
    <div><div class="un" id="un">—</div><div class="ur" id="ur">—</div></div>
    <span class="logout" onclick="doLogout()" title="Logout">⏻</span>
  </div>
  <nav>
    <div class="ng">Overview</div>
    <div class="ni active" onclick="showPage('dashboard')" id="nav-dashboard">📊 Executive Dashboard</div>
    <div class="ni" onclick="showPage('heatmap')" id="nav-heatmap">🌡️ Heatmap</div>
    <div class="ng">Enrollment</div>
    <div class="ni" onclick="showPage('enroll')" id="nav-enroll">➕ Enroll Learner</div>
    <div class="ng">Reports</div>
    <div class="ni" onclick="showPage('sf2')" id="nav-sf2">📋 SF2 Report</div>
    <div class="ni" onclick="showPage('summary')" id="nav-summary">📑 Monthly Summary</div>
    <div class="ng">AI Intelligence</div>
    <div class="ni" onclick="showPage('risk')" id="nav-risk">🤖 AI Risk <span class="nbadge" id="risk-bdg">0</span></div>
    <div class="ng">Tools</div>
    <div class="ni" onclick="openScanner()">📷 Open Scanner</div>
    <div class="ni" onclick="window.print()">🖨️ Print Report</div>
  </nav>
  <div class="sb-bottom">
    <div class="sb-clock" id="sb-clk">--:--:--</div>
    <div class="sb-date" id="sb-dt">Loading…</div>
    <div class="sb-sync" id="sb-sync">Auto-refresh: 30s</div>
  </div>
</aside>

<div class="main">
  <div class="topbar">
    <div><h2 id="page-title">📊 Executive Dashboard</h2><p id="page-sub">Real-time attendance intelligence · Jaliobong NHS</p></div>
    <div class="topbar-r">
      <span class="live-badge"><span class="ldot"></span>LIVE</span>
      <button class="btn btn-ghost btn-sm" onclick="loadAll()">🔄 Refresh</button>
      <button class="btn btn-teal btn-sm" onclick="showPage('sf2')">🖨️ SF2</button>
    </div>
  </div>

  <div class="content">
    <div class="filter-bar">
      <select id="f-grade" onchange="applyF()"><option value="all">All Grades</option><option value="7">Grade 7</option><option value="8">Grade 8</option><option value="9">Grade 9</option><option value="10">Grade 10</option><option value="11">Grade 11</option><option value="12">Grade 12</option></select>
      <select id="f-section" onchange="applyF()"><option value="all">All Sections</option></select>
      <input type="date" id="f-date">
      <button class="btn btn-ghost btn-sm" onclick="clearF()">✕ Clear</button>
    </div>

    <!-- DASHBOARD -->
    <div class="page active" id="page-dashboard">
      <div class="stats">
        <div class="stat s-total" data-icon="👥"><div class="num" id="st-tot">—</div><div class="lbl">Total Scanned</div><div class="bar"><div class="bf" id="bf-tot" style="width:100%"></div></div></div>
        <div class="stat s-present" data-icon="✅"><div class="num" id="st-pre">—</div><div class="lbl">Present</div><div class="bar"><div class="bf" id="bf-pre"></div></div></div>
        <div class="stat s-late" data-icon="⏰"><div class="num" id="st-lat">—</div><div class="lbl">Late</div><div class="bar"><div class="bf" id="bf-lat"></div></div></div>
        <div class="stat s-vlate" data-icon="⚠️"><div class="num" id="st-vl">—</div><div class="lbl">Very Late</div><div class="bar"><div class="bf" id="bf-vl"></div></div></div>
        <div class="stat s-absent" data-icon="❌"><div class="num" id="st-abs">—</div><div class="lbl">Absent</div><div class="bar"><div class="bf" id="bf-abs"></div></div></div>
        <div class="stat s-rate" data-icon="📊"><div class="num" id="st-rate">—%</div><div class="lbl">Rate</div><div class="bar"><div class="bf" id="bf-rate"></div></div></div>
      </div>
      <div class="grid2">
        <div class="card"><div class="ch">📚 By Grade Level <span class="ctag">TODAY</span></div><div class="tbl-wrap"><table><thead><tr><th>Grade</th><th>Present</th><th>Late</th><th>Absent</th><th>Rate</th></tr></thead><tbody id="grade-tbody"></tbody></table></div></div>
        <div class="card"><div class="ch">👩‍🏫 By Adviser <span class="ctag">TODAY</span></div><div class="tbl-wrap" style="max-height:280px;overflow-y:auto"><table><thead><tr><th>Adviser</th><th>Section</th><th>Present</th><th>Rate</th></tr></thead><tbody id="adv-tbody"></tbody></table></div></div>
      </div>
      <div class="card"><div class="ch">📈 7-Day Attendance Trend</div><div class="chart-wrap" id="trend-chart"></div></div>
      <div class="card">
        <div class="ch">🕐 4-Session Summary <span class="ctag">TODAY</span></div>
        <div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:10px;padding:14px" id="session-grid"></div>
      </div>
