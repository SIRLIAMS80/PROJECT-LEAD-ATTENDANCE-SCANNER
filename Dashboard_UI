    if(IS_GAS){
      google.script.run
        .withSuccessHandler(r=>{ if(r.success){showES("✅ Enrolled!",true);document.getElementById("qr-result").style.display="block";document.getElementById("qr-img").src=r.qrUrl;clearEnroll();}else{showES("❌ "+r.message,false);}})
        .withFailureHandler(e=>showES("❌ "+e.message,false))
        .enrollStudent(data);
    } else {
      const r=await fetch(CFG.URL,{method:"POST",headers:{"Content-Type":"text/plain"},body:JSON.stringify({action:"enroll",data}),redirect:"follow"});
      const j=await r.json();
      const res=j.data||j;
      if(res.success){showES("✅ Enrolled!",true);document.getElementById("qr-result").style.display="block";document.getElementById("qr-img").src=res.qrUrl;clearEnroll();}
      else showES("❌ "+(res.message||"Failed"),false);
    }
  }catch(e){showES("❌ "+e.message,false);}
}
function showES(msg,ok){const el=document.getElementById("enroll-status");el.textContent=msg;el.className=ok?"es-ok":"es-err";}

// ════════════════════════════════════
// SF2
// ════════════════════════════════════
function makeSF2(){
  const sec=document.getElementById("sf2-sec").value;
  const mo=parseInt(document.getElementById("sf2-mo").value);
  const yr=parseInt(document.getElementById("sf2-yr").value);
  if(!sec){alert("Select a section first.");return;}
  const p=document.getElementById("sf2-prev");
  p.className="loading";p.textContent="⏳ Generating…";
  setTimeout(()=>buildSF2(sec,mo,yr),400);
}

function buildSF2(sec,mo,yr){
  const info=(dashData.sections||[]).find(s=>s.section===sec)||{};
  const dim=new Date(yr,mo,0).getDate();
  const DOW=["Su","Mo","Tu","We","Th","Fr","Sa"];
  const sDays=[];
  for(let d=1;d<=dim;d++){const wd=new Date(yr,mo-1,d).getDay();if(wd>=1&&wd<=5)sDays.push(d);}
  const dHdr=sDays.map(d=>`<th style="min-width:18px;font-size:7px;padding:1px">${d}<br>${DOW[new Date(yr,mo-1,d).getDay()]}</th>`).join("");
  document.getElementById("sf2-prev").className="";
  document.getElementById("sf2-prev").innerHTML=`
  <div style="max-width:100%">
    <div class="sf2-h"><div style="font-size:10px;font-weight:bold">Republic of the Philippines · Department of Education</div>
    <h1>School Form 2 (SF2) — Learner's Attendance Report</h1><div style="font-size:10px;font-style:italic">For ${MONTHS[mo]} ${yr}</div></div>
    <div class="sf2-meta">
      <div class="sf2-mc"><span class="sf2-ml">School Name:</span><div class="sf2-mv">Jaliobong National High School</div></div>
      <div class="sf2-mc"><span class="sf2-ml">Grade & Section:</span><div class="sf2-mv">${sec}</div></div>
      <div class="sf2-mc"><span class="sf2-ml">Class Adviser:</span><div class="sf2-mv">${info.adviser||"___________"}</div></div>
      <div class="sf2-mc"><span class="sf2-ml">School ID:</span><div class="sf2-mv">____________</div></div>
      <div class="sf2-mc"><span class="sf2-ml">School Year:</span><div class="sf2-mv">${yr}–${yr+1}</div></div>
      <div class="sf2-mc"><span class="sf2-ml">Month:</span><div class="sf2-mv">${MONTHS[mo]} ${yr}</div></div>
    </div>
    <table class="sf2-tbl">
      <thead><tr><th rowspan="2" style="width:20px">No.</th><th rowspan="2" style="text-align:left;width:140px">Learner's Name</th>${dHdr}<th rowspan="2" style="width:26px">Present</th><th rowspan="2" style="width:26px">Absent</th></tr><tr></tr></thead>
      <tbody><tr><td colspan="${sDays.length+4}" style="padding:14px;text-align:center;color:#888">Connect to Attendance_Analytics_Log for real student data.</td></tr></tbody>
    </table>
    <div class="sf2-sig">
      <div class="ss"><div class="sl"></div><div class="sn">${info.adviser||"____________________"}</div><div class="st">Class Adviser</div></div>
      <div class="ss"><div class="sl"></div><div class="sn">____________________</div><div class="st">Master Teacher / Dept. Head</div></div>
      <div class="ss"><div class="sl"></div><div class="sn">____________________</div><div class="st">School Principal</div></div>
    </div>
    <div style="margin-top:8px;font-size:8px;color:#888;text-align:right">Project LEAD · ${new Date().toLocaleDateString("en-PH")}</div>
  </div>`;
}
function printSF2(){if(document.getElementById("sf2-prev").classList.contains("loading")){alert("Generate SF2 first.");return;}window.print();}

// ════════════════════════════════════
// SUMMARY
// ════════════════════════════════════
function makeSummary(){
  const mo=parseInt(document.getElementById("sum-mo").value);
  let tp=0,tl=0,tvl=0,ta=0,te=0;
  const advMap={};(dashData.advisers||[]).forEach(a=>advMap[a.section]=a);
  const rows=(dashData.sections||[]).filter(s=>curSec==="all"||s.section===curSec).map(sec=>{
    const a=advMap[sec.section]||{};
    const p=a.present||0,l=a.late||0,vl=a.veryLate||0,ab=a.absent||0;
    const tot=p+l+vl+ab,rate=tot?Math.round((p+l)/tot*100):0;
    const rc=rate>=90?"var(--green)":rate>=75?"var(--amber)":"var(--red)";
    tp+=p;tl+=l;tvl+=vl;ta+=ab;te+=sec.enrolled||0;
    return`<tr><td><strong>${sec.section}</strong></td><td>Grade ${sec.grade}</td><td style="font-size:12px">${sec.adviser||"—"}</td><td style="font-family:var(--mono)">${sec.enrolled||0}</td><td style="color:var(--green);font-weight:700">${p}</td><td style="color:var(--amber)">${l}</td><td style="color:var(--purple)">${vl}</td><td style="color:var(--red)">${ab}</td><td><strong style="color:${rc};font-family:var(--mono)">${rate}%</strong></td></tr>`;
  });
  const gt=tp+tl+tvl+ta,gr=gt?Math.round((tp+tl)/gt*100):0;
  rows.push(`<tr style="background:var(--navy3);font-weight:800;border-top:2px solid var(--border)"><td colspan="3">GRAND TOTAL — ${MONTHS[mo]}</td><td style="font-family:var(--mono)">${te}</td><td style="color:var(--green)">${tp}</td><td style="color:var(--amber)">${tl}</td><td style="color:var(--purple)">${tvl}</td><td style="color:var(--red)">${ta}</td><td style="font-family:var(--mono);font-weight:800">${gr}%</td></tr>`);
  document.getElementById("sum-tbody").innerHTML=rows.join("")||`<tr><td colspan="9" class="empty-msg">No sections enrolled</td></tr>`;
}

function openScanner(){
  if(IS_GAS) google.script.run.openScannerUI();
  else window.open("index.html","_blank");
}
